# Variables para Railway (copiar al dashboard de Railway)
NODE_ENV=production
PORT=3000

# Database - Railway provee estas variables automáticamente
# DATABASE_URL se genera automáticamente en Railway

# JWT - Generar uno nuevo y seguro
JWT_SECRET=cambiar_por_secreto_muy_largo_y_aleatorio_min_32_chars
JWT_EXPIRES_IN=7d

# CORS - URL del frontend en Vercel
CORS_ORIGIN=https://cercaya.vercel.app

# WebSocket - Railway maneja esto automáticamente
# Solo si necesitas configuración especial
# WSS_URL=wss://tu-backend.railway.app
